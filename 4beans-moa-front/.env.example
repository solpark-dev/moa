# ============================================================
# .env.example — 4beans-moa-front
#
# 로컬 개발: 이 파일을 복사한 뒤 실제 값을 채워 .env.local로 사용하세요.
#            Vite는 .env.local을 .env보다 우선 적용합니다.
#
# AWS 배포:  GitHub Repository Secrets에 아래 VITE_* 키들을 등록하면
#            GitHub Actions가 빌드 시 자동으로 번들에 포함합니다.
#            (프론트엔드는 빌드 타임에 환경변수가 번들에 포함되므로
#             런타임 주입이 아닌 빌드 시 주입이 필요합니다)
# ============================================================

VITE_KAKAO_JAVASCRIPT_KEY=your_kakao_js_key
VITE_KAKAO_REDIRECT_URI=https://localhost:5173/oauth/kakao?mode=connect
VITE_TOSS_CLIENT_KEY=your_toss_client_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
