# ============================================================
# application-secret.properties.example
#
# 로컬 개발: 이 파일을 복사한 뒤 실제 값을 채워
#            application-secret.properties 로 이름을 바꾸거나,
#            IntelliJ Run Configuration에서
#            SECRET_PROPS_PATH=D:/Gitcodes/secrets/moa/application-secret.properties
#            환경변수를 설정하여 외부 파일을 참조하세요.
#
# AWS 배포:  GitHub Repository Secrets에 아래 키들을 등록하면
#            GitHub Actions가 EC2에 .env 파일로 자동 주입합니다.
#            (application-secret.properties 파일 불필요)
# ============================================================

spring.datasource.username=YOUR_DB_USER
spring.datasource.password=YOUR_DB_PASSWORD

portone.imp-key=YOUR_IMP_KEY
portone.imp-secret=YOUR_IMP_SECRET
portone.imp-code=YOUR_IMP_CODE

resend.api-key=YOUR_RESEND_API_KEY

oauth.kakao.client-id=YOUR_KAKAO_CLIENT_ID
oauth.kakao.client-secret=YOUR_KAKAO_CLIENT_SECRET
oauth.google.client-id=YOUR_GOOGLE_CLIENT_ID
oauth.google.client-secret=YOUR_GOOGLE_CLIENT_SECRET

toss.client.api-key=YOUR_TOSS_CLIENT_KEY
toss.secret.api-key=YOUR_TOSS_SECRET_KEY

openbanking.client-id=YOUR_OPENBANKING_CLIENT_ID
openbanking.client-secret=YOUR_OPENBANKING_CLIENT_SECRET

jwt.secret=YOUR_BASE64_JWT_SECRET
jwt.refresh-secret=YOUR_BASE64_JWT_REFRESH_SECRET_AT_LEAST_32_CHARS
jwt.access-token-expiration-millis=1800000
jwt.refresh-token-expiration-millis=1209600000

openai.api.key=YOUR_OPENAI_KEY
ai.api-key=YOUR_NVIDIA_API_KEY

# AES 암호화 키 (32바이트 이상 랜덤 문자열, 없으면 앱 기동 실패)
# 생성 방법 (PowerShell): $rng = [System.Security.Cryptography.RNGCryptoServiceProvider]::new(); $b = New-Object byte[] 32; $rng.GetBytes($b); [Convert]::ToBase64String($b)
# 생성 방법 (Linux/Mac): openssl rand -base64 32
app.security.aes-key=YOUR_AES_KEY_32BYTES_OR_MORE
