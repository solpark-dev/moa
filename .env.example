# ── Database ─────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/moa?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=moa
SPRING_DATASOURCE_PASSWORD=your_db_password

MYSQL_DATABASE=moa
MYSQL_USER=moa
MYSQL_PASSWORD=your_db_password
MYSQL_ROOT_PASSWORD=your_root_password

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=your_base64_jwt_secret
JWT_ACCESS_TOKEN_EXPIRATION_MILLIS=1800000
JWT_REFRESH_TOKEN_EXPIRATION_MILLIS=1209600000

# ── Resend (Email) ────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key

# ── OAuth ─────────────────────────────────────────────────────────
OAUTH_KAKAO_CLIENT_ID=your_kakao_client_id
OAUTH_KAKAO_CLIENT_SECRET=your_kakao_client_secret
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── PortOne (PASS 본인인증) ────────────────────────────────────────
PORTONE_IMP_KEY=your_imp_key
PORTONE_IMP_SECRET=your_imp_secret
PORTONE_IMP_CODE=your_imp_code

# ── Toss Payments ─────────────────────────────────────────────────
TOSS_CLIENT_API_KEY=your_toss_client_key
TOSS_SECRET_API_KEY=your_toss_secret_key

# ── AI / LLM ──────────────────────────────────────────────────────
# 제공자 교체 시 AI_API_KEY 값만 바꾸면 됩니다.
# NVIDIA NIM  : https://build.nvidia.com 에서 발급
# OpenRouter  : https://openrouter.ai/keys 에서 발급
# OpenAI      : https://platform.openai.com/api-keys 에서 발급
AI_API_KEY=your_ai_api_key

# ── Redis ─────────────────────────────────────────────────────────
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ── Security ──────────────────────────────────────────────────────
# 32바이트 랜덤 문자열 (AES-256 암호화 키)
APP_SECURITY_AES_KEY=your_32_byte_aes_key_here_replace

# ── Logging ───────────────────────────────────────────────────────
LOG_PATH=/var/log/moa
